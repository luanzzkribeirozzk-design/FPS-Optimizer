<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FFOptimizer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/orange_ff</item>
        <item name="colorPrimaryVariant">@color/btn_red</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/green_neon</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
    </style>

    <style name="FpsDialogTheme" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">@color/orange_ff</item>
        <item name="colorAccent">@color/orange_ff</item>
        <item name="android:background">@color/card_dark</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/DialogPositiveButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/DialogNegativeButton</item>
    </style>

    <style name="DialogPositiveButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/orange_ff</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DialogNegativeButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
</resources>
