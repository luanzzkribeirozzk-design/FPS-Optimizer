<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FFOptimizer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#1AFF1A</item>
        <item name="colorPrimaryVariant">#00CC00</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorSecondary">#1AFF1A</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:windowBackground">#000000</item>
        <item name="switchStyle">@style/MatrixSwitch</item>
    </style>

    <style name="MatrixSwitch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="thumbTint">@color/matrix_green</item>
        <item name="trackTint">@color/matrix_track</item>
    </style>

    <style name="FpsDialogTheme" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">#1AFF1A</item>
        <item name="colorAccent">#1AFF1A</item>
        <item name="android:background">#0A0A0A</item>
        <item name="android:textColor">#1AFF1A</item>
        <item name="android:textColorPrimary">#1AFF1A</item>
        <item name="buttonBarPositiveButtonStyle">@style/DialogPositiveButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/DialogNegativeButton</item>
    </style>

    <style name="DialogPositiveButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">#1AFF1A</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DialogNegativeButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">#888888</item>
    </style>
</resources>
