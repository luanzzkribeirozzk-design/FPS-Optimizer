<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Partículas Matrix -->
    <com.ffoptimizer.app.ParticleView
        android:id="@+id/particleView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ══ TELA DE BLOQUEIO SHIZUKU ══ -->
    <LinearLayout
        android:id="@+id/layoutShizukuWall"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FPS OPTIMIZER"
            android:textColor="#1AFF1A"
            android:textSize="13sp"
            android:letterSpacing="0.15"
            android:fontFamily="monospace"
            android:paddingBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SHIZUKU"
            android:textColor="#FF00FF"
            android:textSize="52sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NECESSARIO"
            android:textColor="#FF00FF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:gravity="center"
            android:paddingBottom="24dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1AFF1A"
            android:alpha="0.4"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Este app requer o Shizuku ativo para funcionar. Sem ele NADA funciona."
            android:textColor="#1AFF1A"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tvShizukuReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFD600"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:paddingBottom="32dp" />

        <Button
            android:id="@+id/btnInstallShizuku"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="10dp"
            android:text="INSTALAR SHIZUKU"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:fontFamily="monospace"
            android:background="@drawable/btn_matrix_fill"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnRetryShizuku"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="JA ATIVEI — TENTAR NOVAMENTE"
            android:textColor="#1AFF1A"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:fontFamily="monospace"
            android:background="@drawable/btn_matrix_outline"
            android:stateListAnimator="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#10132; play.google.com → Shizuku"
            android:textColor="#1AFF1A"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:alpha="0.5"
            android:paddingTop="20dp" />

    </LinearLayout>

    <!-- ══ CONTEÚDO PRINCIPAL ══ -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="32dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FPS OPTIMIZER -"
                    android:textColor="#1AFF1A"
                    android:textSize="13sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FREE FIRE"
                    android:textColor="#FF00FF"
                    android:textSize="44sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="0.9" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="FREE FIRE · BOOST SYSTEM"
                        android:textColor="#1AFF1A"
                        android:textSize="11sp"
                        android:letterSpacing="0.08"
                        android:fontFamily="monospace" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:id="@+id/statusDot"
                            android:layout_width="7dp"
                            android:layout_height="7dp"
                            android:background="@drawable/dot_green"
                            android:layout_marginEnd="5dp" />

                        <TextView
                            android:id="@+id/tvRootStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VERIFICANDO"
                            android:textColor="#1AFF1A"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            android:fontFamily="monospace" />

                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="#1AFF1A"
                    android:alpha="0.5" />

            </LinearLayout>

            <!-- HIDE STREAM -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HIDE STREAM"
                            android:textColor="#1AFF1A"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.12"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/tvHideStreamStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HIDE STREAM: OFF"
                            android:textColor="#1AFF1A"
                            android:textSize="11sp"
                            android:alpha="0.6"
                            android:fontFamily="monospace"
                            android:paddingTop="2dp" />

                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchHideStream"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="#1AFF1A"
                        android:trackTint="#0A3A0A" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:background="#1AFF1A"
                    android:alpha="0.2" />

            </LinearLayout>

            <!-- BOTÕES -->
            <Button
                android:id="@+id/btnClearCache"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="8dp"
                android:text="LIMPAR CACHE"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:fontFamily="monospace"
                android:background="@drawable/btn_matrix_fill"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnOptimizeFFN"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="2dp"
                android:text="OTIMIZAR FFN"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:fontFamily="monospace"
                android:background="@drawable/btn_matrix_fill"
                android:stateListAnimator="@null" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Free Fire Normal"
                android:textColor="#1AFF1A"
                android:textSize="11sp"
                android:gravity="center"
                android:alpha="0.5"
                android:fontFamily="monospace"
                android:paddingBottom="8dp" />

            <Button
                android:id="@+id/btnOptimizeFFM"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="2dp"
                android:text="OTIMIZAR FFM"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:fontFamily="monospace"
                android:background="@drawable/btn_matrix_fill"
                android:stateListAnimator="@null" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Free Fire MAX"
                android:textColor="#1AFF1A"
                android:textSize="11sp"
                android:gravity="center"
                android:alpha="0.5"
                android:fontFamily="monospace"
                android:paddingBottom="8dp" />

            <Button
                android:id="@+id/btnFps120FFN"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="2dp"
                android:text="FORCA 120 FPS — FFN"
                android:textColor="#1AFF1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:fontFamily="monospace"
                android:background="@drawable/btn_matrix_outline"
                android:stateListAnimator="@null" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Free Fire Normal → 90~120fps"
                android:textColor="#1AFF1A"
                android:textSize="11sp"
                android:gravity="center"
                android:alpha="0.5"
                android:fontFamily="monospace"
                android:paddingBottom="8dp" />

            <Button
                android:id="@+id/btnFps120FFM"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="2dp"
                android:text="FORCA 120 FPS — FFM"
                android:textColor="#1AFF1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:fontFamily="monospace"
                android:background="@drawable/btn_matrix_outline"
                android:stateListAnimator="@null" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Free Fire MAX → 90~120fps"
                android:textColor="#1AFF1A"
                android:textSize="11sp"
                android:gravity="center"
                android:alpha="0.5"
                android:fontFamily="monospace"
                android:paddingBottom="8dp" />

            <Button
                android:id="@+id/btnShowFps"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="8dp"
                android:text="MOSTRAR TAXA FPS"
                android:textColor="#1AFF1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:fontFamily="monospace"
                android:background="@drawable/btn_matrix_outline"
                android:stateListAnimator="@null" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnOpenFFN"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:text="ABRIR FFN"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:fontFamily="monospace"
                    android:background="@drawable/btn_matrix_fill"
                    android:stateListAnimator="@null"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btnOpenFFM"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:text="ABRIR FFM"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:fontFamily="monospace"
                    android:background="@drawable/btn_matrix_fill"
                    android:stateListAnimator="@null" />

            </LinearLayout>

            <!-- TERMINAL LOG -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#050505"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="root@fpsoptimizer:~$ boost_log"
                        android:textColor="#1AFF1A"
                        android:textSize="11sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="v1.0"
                        android:textColor="#1AFF1A"
                        android:textSize="10sp"
                        android:alpha="0.4"
                        android:fontFamily="monospace" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:indeterminate="true"
                    android:indeterminateTint="#1AFF1A"
                    android:visibility="gone"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="60dp"
                    android:text=""
                    android:textColor="#1AFF1A"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:gravity="top"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvCursor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="█"
                    android:textColor="#1AFF1A"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />

            </LinearLayout>

            <Button
                android:id="@+id/btnClearLogs"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:text="LIMPAR LOGS"
                android:textColor="#1AFF1A"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:fontFamily="monospace"
                android:background="@drawable/btn_matrix_outline_dim"
                android:stateListAnimator="@null" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="by FPS OPTIMIZER"
                android:textColor="#1AFF1A"
                android:textSize="10sp"
                android:gravity="center"
                android:alpha="0.25"
                android:fontFamily="monospace"
                android:paddingTop="12dp" />

        </LinearLayout>
    </ScrollView>

</FrameLayout>
